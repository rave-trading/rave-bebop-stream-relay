# Bebop Price API stream authorization key (required)
BEBOP_PRICE_STREAM_AUTH=

# Bebop Price API base URL (default: https://api.bebop.xyz/pmm)
# BEBOP_PRICE_API_URL=https://api.bebop.xyz/pmm

# Internal relay bind address (default: 0.0.0.0:8080)
# BIND_ADDR=0.0.0.0:8080

# Log level (default: info)
# RUST_LOG=info
